{
  "rewrites": [
    { "source": "/((?!assets|icons|favicon|sw|workbox|manifest|registerSW).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
